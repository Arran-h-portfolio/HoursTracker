@page "/tax-rundown"
@using Data.Models
@using TradeLedger.Services
@inject HoursTrackerService TrackerService

<h1 class="main-headings">Tax Rundown</h1>

<body>

@if (!isPremium)
{
    <section class="main-background paywall-section">
        <div class="paywall-content">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="paywall-icon" viewBox="0 0 16 16">
                <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
            </svg>
            <h2 class="paywall-title">Premium Feature</h2>
            <p class="paywall-body">Upgrade to TradeLedger Premium to run a detailed tax breakdown across any date range — perfect for filing your self-assessment.</p>
            <a href="/settings" class="btn-main">View Plans</a>
        </div>
    </section>
}
else
{
    @* Date range selector *@
    <section class="main-background">
        <div class="column-display">
            <h2 class="secondary-headings">Date Range</h2>
            <div class="date-range-row">
                <label class="date-label">
                    From
                    <input type="date" @bind="fromDate" @bind:format="yyyy-MM-dd" />
                </label>
                <label class="date-label">
                    To
                    <input type="date" @bind="toDate" @bind:format="yyyy-MM-dd" />
                </label>
            </div>
            @if (dateError is not null)
            {
                <p class="date-error">@dateError</p>
            }
            <div class="date-actions">
                <button class="btn-secondary" @onclick="SetThisTaxYear">This Tax Year</button>
                <button class="btn-main" @onclick="Calculate">Calculate</button>
            </div>
        </div>
    </section>

    @* Results *@
    @if (result is not null)
    {
        @* Summary card *@
        <section class="main-background">
            <div class="column-display">
                <h2 class="secondary-headings">Tax Summary</h2>
                <div class="tax-summary-grid">
                    <div class="tax-summary-block">
                        <span class="tax-summary-label">Total Hours</span>
                        <span class="tax-summary-value"><AnimatedNumber Value="@result.Total.TotalHours" Format="0.#" /> hrs</span>
                    </div>
                    <div class="tax-summary-block">
                        <span class="tax-summary-label">Gross Earnings</span>
                        <span class="tax-summary-value"><AnimatedNumber Value="@result.Total.GrossEarnings" Format="N2" Prefix="£" /></span>
                    </div>
                    @if (result.Total.TotalExpenses > 0)
                    {
                        <div class="tax-summary-block">
                            <span class="tax-summary-label">Less Expenses</span>
                            <span class="tax-summary-value expenses-value"><AnimatedNumber Value="@result.Total.TotalExpenses" Format="N2" Prefix="-£" /></span>
                        </div>
                        <div class="tax-summary-block">
                            <span class="tax-summary-label">Taxable Profit</span>
                            <span class="tax-summary-value"><AnimatedNumber Value="@result.Total.TaxableProfit" Format="N2" Prefix="£" /></span>
                        </div>
                    }
                    <div class="tax-divider-full"></div>
                    @if (result.UKBreakdown is not null)
                    {
                        @* UK mode: show personal allowance, income tax and NI separately *@
                        <div class="tax-summary-block">
                            <span class="tax-summary-label">Personal Allowance</span>
                            <span class="tax-summary-value"><AnimatedNumber Value="@result.UKBreakdown.PersonalAllowanceUsed" Format="N0" Prefix="£" /> @@0%</span>
                        </div>
                        <div class="tax-summary-block">
                            <span class="tax-summary-label">Income Tax</span>
                            <span class="tax-summary-value tax-value"><AnimatedNumber Value="@result.UKBreakdown.IncomeTax" Format="N2" Prefix="£" /></span>
                        </div>
                        @if (result.UKBreakdown.ClassFourNI > 0)
                        {
                            <div class="tax-summary-block">
                                <span class="tax-summary-label">Class 4 NI</span>
                                <span class="tax-summary-value tax-value"><AnimatedNumber Value="@result.UKBreakdown.ClassFourNI" Format="N2" Prefix="£" /></span>
                            </div>
                        }
                        <div class="tax-divider-full"></div>
                        <div class="tax-summary-block highlight-tax">
                            <span class="tax-summary-label">Total Tax Owed</span>
                            <span class="tax-summary-value tax-value"><AnimatedNumber Value="@result.Total.TaxAmount" Format="N2" Prefix="£" /></span>
                        </div>
                    }
                    else
                    {
                        <div class="tax-summary-block highlight-tax">
                            <span class="tax-summary-label">Tax Owed (@(taxRatePct.ToString("0.#"))%)</span>
                            <span class="tax-summary-value tax-value"><AnimatedNumber Value="@result.Total.TaxAmount" Format="N2" Prefix="£" /></span>
                        </div>
                    }
                    <div class="tax-summary-block">
                        <span class="tax-summary-label">Net Earnings</span>
                        <span class="tax-summary-value net-value"><AnimatedNumber Value="@result.Total.NetEarnings" Format="N2" Prefix="£" /></span>
                    </div>
                </div>
                @if (result.UKBreakdown is not null)
                {
                    <p class="uk-tax-note">2024/25 UK self-employed rates. Assumes this is your only income source.</p>
                }
            </div>
        </section>

        @* Monthly breakdown *@
        @if (result.Monthly.Count > 1)
        {
            <section class="main-background">
                <div class="column-display">
                    <h2 class="secondary-headings">Month by Month</h2>
                    @if (useUKTax)
                    {
                        <p class="uk-tax-note" style="text-align:left;margin:0 0 4px;">Tax is calculated on the period total above, not per month.</p>
                    }
                    <div class="breakdown-table">
                        <div class="breakdown-header">
                            <span>Month</span>
                            <span>Hrs</span>
                            <span>Gross</span>
                            @if (useUKTax)
                            {
                                <span>Exp</span>
                                <span>Profit</span>
                            }
                            else
                            {
                                <span>Tax</span>
                                <span>Net</span>
                            }
                        </div>
                        @foreach (var row in result.Monthly)
                        {
                            var hasData = row.Earnings.TotalHours > 0 || row.Earnings.TotalExpenses > 0;
                            <div class="breakdown-row @(!hasData ? "empty-row" : "")">
                                <span class="breakdown-month">@row.Month.ToString("MMM yy")</span>
                                <span>@(row.Earnings.TotalHours > 0 ? row.Earnings.TotalHours.ToString("0.#") : "—")</span>
                                <span>@(row.Earnings.TotalHours > 0 ? $"£{row.Earnings.GrossEarnings:N0}" : "—")</span>
                                @if (useUKTax)
                                {
                                    <span class="col-tax">@(row.Earnings.TotalExpenses > 0 ? $"£{row.Earnings.TotalExpenses:N0}" : "—")</span>
                                    <span class="col-net">@(row.Earnings.TotalHours > 0 ? $"£{row.Earnings.TaxableProfit:N0}" : "—")</span>
                                }
                                else
                                {
                                    <span class="col-tax">@(row.Earnings.TotalHours > 0 ? $"£{row.Earnings.TaxAmount:N0}" : "—")</span>
                                    <span class="col-net">@(row.Earnings.TotalHours > 0 ? $"£{row.Earnings.NetEarnings:N0}" : "—")</span>
                                }
                            </div>
                        }
                        @if (!useUKTax)
                        {
                            <div class="breakdown-row total-row">
                                <span class="breakdown-month">Total</span>
                                <span>@result.Total.TotalHours.ToString("0.#")</span>
                                <span>£@result.Total.GrossEarnings.ToString("N0")</span>
                                <span class="col-tax">£@result.Total.TaxAmount.ToString("N0")</span>
                                <span class="col-net">£@result.Total.NetEarnings.ToString("N0")</span>
                            </div>
                        }
                    </div>
                </div>
            </section>
        }
    }
}

</body>

@code {
    private bool isPremium;
    private bool useUKTax;
    private AppSettings currentSettings = new();
    private DateTime fromDate = new DateTime(DateTime.Today.Year, 1, 1);
    private DateTime toDate   = DateTime.Today;
    private TaxRundownResult? result;
    private string? dateError;

    private double taxRatePct => currentSettings.TaxRate * 100;

    protected override async Task OnInitializedAsync()
    {
        currentSettings = await TrackerService.GetSettingsAsync();
        isPremium = currentSettings.IsPremium;
        useUKTax  = currentSettings.UseUKTax;
    }

    private async Task Calculate()
    {
        dateError = null;
        var from = DateOnly.FromDateTime(fromDate);
        var to   = DateOnly.FromDateTime(toDate);

        if (from > to)
        {
            dateError = "Start date must be before end date.";
            return;
        }

        currentSettings = await TrackerService.GetSettingsAsync();
        useUKTax = currentSettings.UseUKTax;
        result   = await TrackerService.GetTaxRundownAsync(from, to);
    }

    private async Task SetThisTaxYear()
    {
        var today     = DateTime.Today;
        var startYear = (today.Month > 4 || (today.Month == 4 && today.Day >= 6))
                        ? today.Year : today.Year - 1;
        fromDate = new DateTime(startYear, 4, 6);
        toDate   = today;
        await Calculate();
    }
}
