@page "/settings"
@using Data.Models
@using TradeLedger.Services
@inject HoursTrackerService TrackerService
@inject NotificationService NotifService
@inject IJSRuntime JS

<body>
    <section class="main-background">
        <div class="column-display">
            <h2 class="secondary-headings">Tax Mode</h2>
            <div class="period-type-toggle">
                <button class="@TaxModeClass(false)" @onclick="() => useUKTax = false">Simple</button>
                <button class="@TaxModeClass(true)"  @onclick="() => useUKTax = true">UK Self-Employed</button>
            </div>
            @if (!useUKTax)
            {
                <label class="secondary-headings" style="margin-top:4px;">
                    Tax Rate (%)
                    <input type="number" min="0" max="100" step="0.1" @bind="taxRatePercent" @bind:event="oninput" />
                </label>
                <p class="settings-hint">A flat percentage applied to your taxable profit each period.</p>
            }
            else
            {
                <div class="uk-tax-info">
                    <div class="uk-tax-line"><span class="uk-tax-key">Personal Allowance</span><span>£12,570 @@0%</span></div>
                    <div class="uk-tax-line"><span class="uk-tax-key">Basic Rate</span><span>£12,571–£50,270 @@20%</span></div>
                    <div class="uk-tax-line"><span class="uk-tax-key">Higher Rate</span><span>£50,271–£125,140 @@40%</span></div>
                    <div class="uk-tax-line"><span class="uk-tax-key">Additional Rate</span><span>Above £125,140 @@45%</span></div>
                    <div class="uk-tax-line"><span class="uk-tax-key">Class 4 NI</span><span>£12,571–£50,270 @@6%, above @@2%</span></div>
                </div>
                <p class="settings-hint">2024/25 UK rates. Class 2 NI abolished April 2024. Accurate tax shown in Tax Rundown only — period figures use your flat rate for quick reference.</p>
            }
        </div>
    </section>

    <section class="main-background">
        <div class="column-display">
            <h2 class="secondary-headings">Hourly Wage</h2>
            <div class="row-display">
                <label class="secondary-headings">
                    Hourly Wage (£)
                    <input type="number" min="0" max="999" step="0.01" @bind="hourlyWage" @bind:event="oninput" />
                </label>
            </div>
        </div>
    </section>

    <section class="main-background">
        <div class="column-display">
            <h2 class="secondary-headings">Pay Period</h2>

            <div class="period-type-toggle">
                <button class="@(payPeriodType == PayPeriodType.Monthly ? "toggle-btn active" : "toggle-btn")"
                        @onclick="() => payPeriodType = PayPeriodType.Monthly">
                    Monthly
                </button>
                <button class="@(payPeriodType == PayPeriodType.Weekly ? "toggle-btn active" : "toggle-btn")"
                        @onclick="() => payPeriodType = PayPeriodType.Weekly">
                    Weekly
                </button>
            </div>

            @if (payPeriodType == PayPeriodType.Monthly)
            {
                <label class="secondary-headings">
                    Period starts on day
                    <input type="number" min="1" max="28" step="1" @bind="payPeriodStartDay" @bind:event="oninput" />
                </label>
                <p class="settings-hint">e.g. 1 = 1st of each month, 23 = 23rd of each month</p>
            }
            else
            {
                <label class="secondary-headings">
                    Week starts on
                    <select @bind="payPeriodStartDay">
                        <option value="1">Monday</option>
                        <option value="2">Tuesday</option>
                        <option value="3">Wednesday</option>
                        <option value="4">Thursday</option>
                        <option value="5">Friday</option>
                        <option value="6">Saturday</option>
                        <option value="0">Sunday</option>
                    </select>
                </label>
            }
        </div>
    </section>

    <button class="btn-main" @onclick="SaveSettings">Save</button>

    <section class="main-background">
        <div class="column-display">
            <h2 class="secondary-headings">Appearance</h2>
            <div class="theme-toggle">
                <button class="@ThemeClass("system")"  @onclick='() => SetTheme("system")'>System</button>
                <button class="@ThemeClass("light")"   @onclick='() => SetTheme("light")'>Light</button>
                <button class="@ThemeClass("dark")"    @onclick='() => SetTheme("dark")'>Dark</button>
            </div>
            <p class="settings-hint">System follows your device's dark/light mode setting.</p>
        </div>
    </section>

    <section class="main-background">
        <div class="column-display">
            <h2 class="secondary-headings">Daily Reminder</h2>
            <div class="notif-row">
                <label class="notif-label">Remind me to log hours</label>
                <button class="toggle-switch @(notificationsEnabled ? "on" : "")" @onclick="ToggleNotifications"
                        role="switch" aria-checked="@notificationsEnabled">
                    <span class="toggle-thumb"></span>
                </button>
            </div>
            @if (notificationsEnabled)
            {
                <div class="working-days-group">
                    <span class="notif-label">Working days</span>
                    <div class="day-chips">
                        @foreach (var (dayLabel, dow) in Days)
                        {
                            var active = IsDaySelected(dow);
                            <button class="day-chip @(active ? "active" : "")"
                                    @onclick="() => ToggleDay(dow)">@dayLabel</button>
                        }
                    </div>
                </div>
                <div class="notif-time-row">
                    <label class="secondary-headings" style="text-transform:none;letter-spacing:normal;font-size:0.875rem;color:var(--color-text);">
                        Reminder time
                        <div class="time-select-group">
                            <select @bind="notificationHour">
                                @for (int h = 0; h < 24; h++)
                                {
                                    var display = h == 0 ? "12 AM" : h < 12 ? $"{h} AM" : h == 12 ? "12 PM" : $"{h - 12} PM";
                                    <option value="@h">@display</option>
                                }
                            </select>
                            <select @bind="notificationMinute">
                                <option value="0">:00</option>
                                <option value="15">:15</option>
                                <option value="30">:30</option>
                                <option value="45">:45</option>
                            </select>
                        </div>
                    </label>
                </div>
                <button class="btn-main" style="align-self:flex-start;margin-top:4px" @onclick="SaveNotification">
                    Save Reminder
                </button>
            }
        </div>
    </section>

    <section class="main-background">
        <div class="column-display">
            <h2 class="secondary-headings">Subscription</h2>
            @if (isPremium)
            {
                <div class="subscription-badge premium">Premium Active</div>

                <label class="secondary-headings" style="width:100%;margin-top:12px;">
                    Period Earnings Goal (£)
                    <input type="number" min="0" max="99999" step="10"
                           @bind="earningsGoal" @bind:event="oninput" />
                </label>
                <p class="settings-hint">
                    Your net earnings target per @(payPeriodType == PayPeriodType.Weekly ? "week" : "month").
                    A progress bar appears on the Home screen. Set to 0 to hide it.
                </p>

                <p class="settings-hint">You have full access to the Dashboard, yearly review, tax rundown and CSV export.</p>
                <button class="btn-secondary" @onclick="TogglePremium">Deactivate Premium</button>
            }
            else
            {
                <div class="plan-compare">
                    <div class="plan-card">
                        <span class="plan-name">Free</span>
                        <ul class="plan-features">
                            <li>Daily shift logging</li>
                            <li>Gross &amp; net earnings</li>
                            <li>Tax calculator</li>
                            <li>3-period history</li>
                            <li>Period comparison</li>
                        </ul>
                    </div>
                    <div class="plan-card premium-card">
                        <span class="plan-name">Premium</span>
                        <ul class="plan-features">
                            <li>Everything in Free</li>
                            <li>Earnings goal &amp; progress bar</li>
                            <li>Full yearly review</li>
                            <li>Earnings dashboard</li>
                            <li>Tax rundown by period</li>
                            <li>Export to CSV</li>
                        </ul>
                    </div>
                </div>
                <button class="btn-main" @onclick="TogglePremium">Upgrade to Premium</button>
                <p class="settings-hint">In the published app this links to your App Store or Google Play subscription.</p>
            }
        </div>
    </section>
</body>

@code {
    private static readonly (string Label, DayOfWeek Day)[] Days =
    [
        ("Mo", DayOfWeek.Monday),
        ("Tu", DayOfWeek.Tuesday),
        ("We", DayOfWeek.Wednesday),
        ("Th", DayOfWeek.Thursday),
        ("Fr", DayOfWeek.Friday),
        ("Sa", DayOfWeek.Saturday),
        ("Su", DayOfWeek.Sunday),
    ];

    private double taxRatePercent;
    private double hourlyWage;
    private PayPeriodType payPeriodType;
    private int payPeriodStartDay;
    private bool isPremium;
    private bool useUKTax;
    private double earningsGoal;
    private string themePreference = "system";
    private bool notificationsEnabled;
    private int notificationHour   = 18;
    private int notificationMinute = 0;
    private int workingDays        = 62;

    protected override async Task OnInitializedAsync()
    {
        var settings = await TrackerService.GetSettingsAsync();
        taxRatePercent       = settings.TaxRate * 100;
        hourlyWage           = settings.HourlyWage;
        payPeriodType        = settings.PayPeriodType;
        payPeriodStartDay    = settings.PayPeriodStartDay;
        isPremium            = settings.IsPremium;
        useUKTax             = settings.UseUKTax;
        earningsGoal         = settings.EarningsGoal;
        themePreference      = settings.ThemePreference;
        notificationsEnabled = settings.NotificationsEnabled;
        notificationHour     = settings.NotificationHour;
        notificationMinute   = settings.NotificationMinute;
        workingDays          = settings.WorkingDays;
    }

    private bool IsDaySelected(DayOfWeek day) => (workingDays & (1 << (int)day)) != 0;

    private void ToggleDay(DayOfWeek day)
    {
        if (IsDaySelected(day)) workingDays &= ~(1 << (int)day);
        else                     workingDays |=  (1 << (int)day);
    }

    private async Task SaveSettings()
    {
        var settings = await TrackerService.GetSettingsAsync();
        settings.TaxRate = Math.Clamp(taxRatePercent, 0, 100) / 100.0;
        settings.HourlyWage = Math.Clamp(hourlyWage, 0, 999);
        settings.PayPeriodType = payPeriodType;
        settings.PayPeriodStartDay = payPeriodType == PayPeriodType.Monthly
            ? Math.Clamp(payPeriodStartDay, 1, 28)
            : Math.Clamp(payPeriodStartDay, 0, 6);
        settings.UseUKTax      = useUKTax;
        settings.EarningsGoal  = Math.Max(earningsGoal, 0);
        await TrackerService.SaveSettingsAsync(settings);
    }

    private async Task SetTheme(string preference)
    {
        themePreference = preference;
        var settings = await TrackerService.GetSettingsAsync();
        settings.ThemePreference = preference;
        await TrackerService.SaveSettingsAsync(settings);
        await JS.InvokeVoidAsync("applyTheme", preference);
    }

    private string ThemeClass(string theme) =>
        themePreference == theme ? "toggle-btn active" : "toggle-btn";

    private string TaxModeClass(bool isUK) =>
        useUKTax == isUK ? "toggle-btn active" : "toggle-btn";

    private async Task ToggleNotifications()
    {
        notificationsEnabled = !notificationsEnabled;
        var settings = await TrackerService.GetSettingsAsync();
        settings.NotificationsEnabled = notificationsEnabled;
        await TrackerService.SaveSettingsAsync(settings);

        if (!notificationsEnabled)
            NotifService.CancelDailyReminder();
    }

    private async Task SaveNotification()
    {
        var settings = await TrackerService.GetSettingsAsync();
        settings.NotificationHour     = notificationHour;
        settings.NotificationMinute   = notificationMinute;
        settings.NotificationsEnabled = true;
        settings.WorkingDays          = workingDays;
        await TrackerService.SaveSettingsAsync(settings);
        await NotifService.ScheduleWorkingDayRemindersAsync(notificationHour, notificationMinute, workingDays);
    }

    private async Task TogglePremium()
    {
        var settings = await TrackerService.GetSettingsAsync();
        settings.IsPremium = !settings.IsPremium;
        await TrackerService.SaveSettingsAsync(settings);
        isPremium = settings.IsPremium;
    }
}
