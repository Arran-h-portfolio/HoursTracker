@page "/"
@using Data.Models
@using TradeLedger.Services
@inject HoursTrackerService TrackerService

<h1 class="main-headings">Salary Tracker</h1>
<body>
@*Earnings card — shows stats for the selected pay period with navigation arrows*@
<section class="main-background"
         @ontouchstart="OnEarningsSwipeStart"
         @ontouchend="OnEarningsSwipeEnd">
    <div class="period-nav">
        <button class="btn-period-nav" title="Previous period" @onclick="PreviousPeriod">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/>
            </svg>
        </button>
        <span class="period-label">@PeriodLabel</span>
        <button class="btn-period-nav" title="Next period" @onclick="NextPeriod">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
            </svg>
        </button>
    </div>

    <div class="stat-divider"></div>

    <div class="column-display">
        <div class="stat-block">
            <span class="secondary-headings">Hours This Period</span>
            <span class="stat-value"><AnimatedNumber Value="@totalHours" Format="0.##" /> hrs</span>
        </div>
        @if (totalHours > 0 && grossEarnings == 0)
        {
            <div class="stat-divider"></div>
            <p class="secondary-headings">Set your hourly wage in Settings to see earnings.</p>
        }
        else
        {
            <div class="stat-divider"></div>
            <div class="stat-block">
                <span class="secondary-headings">Gross Earnings</span>
                <span class="stat-value earnings"><AnimatedNumber Value="@grossEarnings" Format="N2" Prefix="£" /></span>
                @if (periodComparisonText is not null)
                {
                    <span class="period-comparison @(comparisonIsPositive ? "arrow-up" : "arrow-down")">
                        @periodComparisonText
                    </span>
                }
            </div>
            @if (totalExpenses > 0)
            {
                <div class="stat-divider"></div>
                <div class="stat-block">
                    <span class="secondary-headings">Less Expenses</span>
                    <span class="stat-value expenses-amount">-£@totalExpenses.ToString("N2")</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-block">
                    <span class="secondary-headings">Taxable Profit</span>
                    <span class="stat-value profit-amount"><AnimatedNumber Value="@taxableProfit" Format="N2" Prefix="£" /></span>
                </div>
            }
            <div class="stat-divider"></div>
            <div class="stat-block">
                <span class="secondary-headings">Tax This Period</span>
                <span class="stat-value tax-amount"><AnimatedNumber Value="@taxAmount" Format="N2" Prefix="£" /></span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-block">
                <span class="secondary-headings">Net Earnings</span>
                <span class="stat-value net-earnings"><AnimatedNumber Value="@netEarnings" Format="N2" Prefix="£" /></span>
            </div>
            @if (currentSettings.IsPremium && currentSettings.EarningsGoal > 0)
            {
                <div class="stat-divider"></div>
                <div class="goal-block">
                    <div class="goal-header">
                        <span class="secondary-headings">Period Goal</span>
                        <span class="goal-pct @(goalPercent >= 100 ? "goal-pct-achieved" : "")">
                            @(goalPercent >= 100 ? "✓ Achieved" : $"{Math.Min(goalPercent, 100):F0}%")
                        </span>
                    </div>
                    <div class="goal-track">
                        <div class="goal-fill @(goalPercent >= 100 ? "achieved" : "")"
                             style="width: @GoalFillWidth">
                        </div>
                    </div>
                    <span class="goal-amounts">£@netEarnings.ToString("N0") of £@currentSettings.EarningsGoal.ToString("N0") net</span>
                </div>
            }
        }
    </div>
</section>

@*Year-to-date profit chip*@
@if (ytdGross > 0)
{
    <section class="main-background ytd-card">
        <div class="ytd-row">
            <div class="ytd-block">
                <span class="ytd-label">Tax Year to Date</span>
                <span class="ytd-value">£@ytdProfit.ToString("N0") profit</span>
                <span class="ytd-since">since 6 Apr @taxYearStartYear</span>
            </div>
            <a href="/tax-rundown" class="ytd-link">Tax Rundown →</a>
        </div>
    </section>
}

@*Expense log form*@
<section class="main-background">
    <div class="column-display">
        <h2 class="secondary-headings">Log Expense</h2>
        <div class="row-display">
            <label class="secondary-headings">Date
                <input type="date" @bind="expenseDate" @bind:format="yyyy-MM-dd" />
            </label>
            <label class="secondary-headings">Amount (£)
                <input type="number" min="0" max="99999" step="0.01" @bind="expenseAmount" @bind:event="oninput" />
            </label>
        </div>
        <div class="row-display" style="margin-top:8px;">
            <label class="secondary-headings">Category
                <select @bind="expenseCategory">
                    <option value="0">Materials</option>
                    <option value="1">Travel</option>
                    <option value="2">Equipment</option>
                    <option value="3">Other</option>
                </select>
            </label>
        </div>
        <div class="row-display" style="margin-top:8px;">
            <label class="secondary-headings" style="flex:1;">Description (optional)
                <input type="text" class="text-input" maxlength="80" placeholder="e.g. Copper pipes"
                       @bind="expenseDescription" @bind:event="oninput" />
            </label>
        </div>
        <button class="btn-main" @onclick="AddExpense">Log Expense</button>
    </div>
</section>

@*Expenses this period*@
<section class="main-background">
    <div class="column-display">
        <h2 class="secondary-headings">Expenses This Period</h2>
        @if (!expensesLogged.Any())
        {
            <div class="empty-state">
                <svg class="empty-icon" viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg" fill="none">
                    <path d="M14 8 H42 V40 L37 36 L32 40 L27 36 L22 40 L17 36 L14 40 Z"
                          stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
                    <line x1="21" y1="18" x2="35" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="21" y1="25" x2="30" y2="25" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="21" y1="32" x2="33" y2="32" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <p class="empty-title">No expenses this period</p>
                <p class="empty-subtitle">Track materials, travel and equipment below</p>
            </div>
        }
        else
        {
            <ul class="log-list">
                @foreach (var exp in expensesLogged)
                {
                    <li>
                        <div class="expense-left">
                            <span class="entry-date">@exp.Date.ToString("ddd, dd MMM")</span>
                            @if (!string.IsNullOrWhiteSpace(exp.Description))
                            {
                                <span class="expense-description">@exp.Description</span>
                            }
                        </div>
                        <div class="entry-actions">
                            <span class="expense-chip @exp.Category.ToString().ToLower()">@exp.Category</span>
                            <span class="entry-hours">£@exp.Amount.ToString("N2")</span>
                            <button class="btn-icon danger" title="Delete" @onclick="() => DeleteExpense(exp.Id)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                                    <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                                </svg>
                            </button>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</section>

@*Shift input card*@
<section class="main-background">
    <div>
        <div class="row-display">
            <label class="secondary-headings">Date
                <input type="date" @bind="selectedDate" @bind:format="yyyy-MM-dd" />
            </label>
        </div>
        <div class="row-display" style="margin-top: 12px;">
            <label class="secondary-headings">Shift Start
                <input type="time" @bind="shiftStart" />
            </label>
            <label class="secondary-headings">Shift End
                <input type="time" @bind="shiftEnd" />
            </label>
        </div>
        <button class="btn-main" @onclick="AddHours">Log Shift</button>
    </div>
</section>

@*Daily log*@
<section class="main-background">
    <div class="column-display">
        <h2 class="secondary-headings">Daily Log</h2>
        @{
            var periodEntries = hoursLogged
                .Where(e => e.Key >= periodStart && e.Key <= periodEnd)
                .OrderByDescending(e => e.Key)
                .ToList();
        }
        @if (!periodEntries.Any())
        {
            <div class="empty-state">
                <svg class="empty-icon" viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg" fill="none">
                    <circle cx="28" cy="28" r="20" stroke="currentColor" stroke-width="2.5"/>
                    <circle cx="28" cy="28" r="2" fill="currentColor"/>
                    <line x1="28" y1="28" x2="28" y2="13" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="28" y1="28" x2="39" y2="28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <p class="empty-title">No shifts this period</p>
                <p class="empty-subtitle">Use the form below to log your first shift</p>
            </div>
        }
        <ul class="log-list">
            @foreach (var entry in periodEntries)
            {
                <li>
                    <span class="entry-date">@entry.Key.ToString("dddd, dd MMM yyyy")</span>
                    <div class="entry-actions">
                        @if (editingDate == entry.Key)
                        {
                            <input class="entry-edit-input" type="number" min="0" max="24" step="0.25"
                                   @bind="editingHours" @bind:event="oninput" />
                            <button class="btn-icon save" title="Save" @onclick="SaveEdit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/>
                                </svg>
                            </button>
                            <button class="btn-icon" title="Cancel" @onclick="CancelEdit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                                </svg>
                            </button>
                        }
                        else
                        {
                            <span class="entry-hours">@entry.Value.ToString("0.##") hrs</span>
                            <button class="btn-icon" title="Edit" @onclick="() => StartEdit(entry.Key, entry.Value)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207l6.5-6.5zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11l.178-.178z"/>
                                </svg>
                            </button>
                            <button class="btn-icon danger" title="Delete" @onclick="() => DeleteEntry(entry.Key)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                                    <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                                </svg>
                            </button>
                        }
                    </div>
                </li>
            }
        </ul>
    </div>
</section>

@*Recent periods history*@
<section class="main-background">
    <div class="column-display">
        <h2 class="secondary-headings">Recent Periods</h2>
        <div class="history-table">
            @foreach (var row in recentPeriods)
            {
                <div class="history-row">
                    <span class="history-period-label">@row.Label</span>
                    <div class="history-stats">
                        <span class="history-stat">@row.Summary.TotalHours.ToString("0.##") hrs</span>
                        <span class="history-stat gross">£@row.Summary.GrossEarnings.ToString("N2")</span>
                        @if (row.Summary.TotalExpenses > 0)
                        {
                            <span class="history-stat expenses">-£@row.Summary.TotalExpenses.ToString("N2") exp</span>
                        }
                        <span class="history-stat tax">£@row.Summary.TaxAmount.ToString("N2") tax</span>
                        <span class="history-stat net">£@row.Summary.NetEarnings.ToString("N2") net</span>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
</body>

@code {
    // Earnings state
    private Dictionary<DateOnly, double> hoursLogged = new();
    private double grossEarnings;
    private double totalExpenses;
    private double taxableProfit;
    private double taxAmount;
    private double netEarnings;
    private double totalHours;
    private string? periodComparisonText;
    private bool comparisonIsPositive;
    private List<(string Label, EarningsSummary Summary)> recentPeriods = new();

    // Year-to-date chip
    private double ytdGross;
    private double ytdProfit;
    private int taxYearStartYear => (DateTime.Today.Month > 4 || (DateTime.Today.Month == 4 && DateTime.Today.Day >= 6))
                                    ? DateTime.Today.Year : DateTime.Today.Year - 1;

    // Shift form
    private DateTime selectedDate = DateTime.Today;
    private TimeOnly shiftStart = new TimeOnly(9, 0);
    private TimeOnly shiftEnd = TimeOnly.FromDateTime(DateTime.Now);

    // Expense form
    private List<Expense> expensesLogged = new();
    private DateTime expenseDate = DateTime.Today;
    private double expenseAmount;
    private int expenseCategory = (int)ExpenseCategory.Materials;
    private string expenseDescription = string.Empty;

    private DateOnly? editingDate = null;
    private double editingHours = 0;

    private int periodOffset = 0;
    private DateOnly periodStart;
    private DateOnly periodEnd;
    private AppSettings currentSettings = new();

    private string PeriodLabel => FormatPeriodLabel(currentSettings, periodStart, periodEnd);

    private double goalPercent => currentSettings.EarningsGoal > 0
        ? (netEarnings / currentSettings.EarningsGoal) * 100
        : 0;

    private string GoalFillWidth =>
        Math.Min(Math.Max(goalPercent, 0), 100)
            .ToString("F1", System.Globalization.CultureInfo.InvariantCulture) + "%";

    private static string FormatPeriodLabel(AppSettings settings, DateOnly start, DateOnly end)
    {
        if (settings.PayPeriodType == PayPeriodType.Weekly)
        {
            return start.Month == end.Month
                ? $"{start.Day}–{end.Day} {start:MMM yyyy}"
                : $"{start.Day} {start:MMM} – {end.Day} {end:MMM yyyy}";
        }
        // Monthly: if period starts on the 1st, "June 2026" is cleaner than "1 Jun – 30 Jun 2026"
        return settings.PayPeriodStartDay == 1
            ? start.ToString("MMMM yyyy")
            : $"{start.Day} {start:MMM} – {end.Day} {end:MMM yyyy}";
    }

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        currentSettings = await TrackerService.GetSettingsAsync();
        (periodStart, periodEnd) = HoursTrackerService.GetPayPeriodBounds(currentSettings, periodOffset);

        hoursLogged = await TrackerService.GetHoursLoggedAsync();
        var summary = await TrackerService.GetPeriodEarningsSummaryAsync(periodStart, periodEnd);
        grossEarnings = summary.GrossEarnings;
        totalExpenses = summary.TotalExpenses;
        taxableProfit = summary.TaxableProfit;
        taxAmount     = summary.TaxAmount;
        netEarnings   = summary.NetEarnings;
        totalHours    = summary.TotalHours;

        expensesLogged = await TrackerService.GetExpensesInPeriodAsync(periodStart, periodEnd);

        var (prevStart, prevEnd) = HoursTrackerService.GetPayPeriodBounds(currentSettings, periodOffset - 1);
        var prevSummary = await TrackerService.GetPeriodEarningsSummaryAsync(prevStart, prevEnd);
        if (prevSummary.GrossEarnings == 0)
        {
            periodComparisonText = null;
        }
        else
        {
            var pct = ((grossEarnings - prevSummary.GrossEarnings) / prevSummary.GrossEarnings) * 100;
            comparisonIsPositive = pct >= 0;
            periodComparisonText = $"{(pct >= 0 ? "↑" : "↓")} {Math.Abs(pct):0.#}% vs last period";
        }

        recentPeriods = new();
        for (int i = -2; i <= 0; i++)
        {
            var (s, e) = HoursTrackerService.GetPayPeriodBounds(currentSettings, i);
            var sum = await TrackerService.GetPeriodEarningsSummaryAsync(s, e);
            recentPeriods.Add((FormatPeriodLabel(currentSettings, s, e), sum));
        }

        var ytd   = await TrackerService.GetYearToDateSummaryAsync();
        ytdGross  = ytd.GrossEarnings;
        ytdProfit = ytd.TaxableProfit;
    }

    // ── Period swipe gesture ──────────────────────────────────────────────────
    private double _swipeStartX;
    private double _swipeStartY;

    private void OnEarningsSwipeStart(TouchEventArgs e)
    {
        if (e.ChangedTouches.Length > 0)
        {
            _swipeStartX = e.ChangedTouches[0].ClientX;
            _swipeStartY = e.ChangedTouches[0].ClientY;
        }
    }

    private async Task OnEarningsSwipeEnd(TouchEventArgs e)
    {
        if (e.ChangedTouches.Length == 0) return;
        var dx = _swipeStartX - e.ChangedTouches[0].ClientX;
        var dy = _swipeStartY - e.ChangedTouches[0].ClientY;
        // Only fire if horizontal movement is dominant and exceeds 48px
        if (Math.Abs(dx) > 48 && Math.Abs(dx) > Math.Abs(dy))
        {
            if (dx > 0) await NextPeriod();
            else        await PreviousPeriod();
        }
    }

    // ── Navigation ────────────────────────────────────────────────────────────
    private async Task PreviousPeriod()
    {
        periodOffset--;
        await RefreshAsync();
    }

    private async Task NextPeriod()
    {
        periodOffset++;
        await RefreshAsync();
    }

    // ── Mutating actions (all trigger a light haptic tap) ─────────────────────
    public async Task AddHours()
    {
        Haptic(HapticFeedbackType.Click);
        double hours = (shiftEnd - shiftStart).TotalHours;
        await TrackerService.LogHoursAsync(DateOnly.FromDateTime(selectedDate), hours);
        await RefreshAsync();
    }

    private void StartEdit(DateOnly date, double currentHours)
    {
        editingDate = date;
        editingHours = currentHours;
    }

    private void CancelEdit() => editingDate = null;

    private async Task SaveEdit()
    {
        if (editingDate is not null)
        {
            Haptic(HapticFeedbackType.Click);
            await TrackerService.LogHoursAsync(editingDate.Value, editingHours);
            editingDate = null;
            await RefreshAsync();
        }
    }

    private async Task DeleteEntry(DateOnly date)
    {
        Haptic(HapticFeedbackType.LongPress);
        await TrackerService.DeleteHoursAsync(date);
        await RefreshAsync();
    }

    private async Task AddExpense()
    {
        if (expenseAmount <= 0) return;
        Haptic(HapticFeedbackType.Click);
        await TrackerService.LogExpenseAsync(new Expense
        {
            Date        = DateOnly.FromDateTime(expenseDate),
            Amount      = expenseAmount,
            Category    = (ExpenseCategory)expenseCategory,
            Description = expenseDescription.Trim()
        });
        expenseAmount      = 0;
        expenseDescription = string.Empty;
        await RefreshAsync();
    }

    private async Task DeleteExpense(int id)
    {
        Haptic(HapticFeedbackType.LongPress);
        await TrackerService.DeleteExpenseAsync(id);
        await RefreshAsync();
    }

    private static void Haptic(HapticFeedbackType type)
    {
        try { HapticFeedback.Default.Perform(type); } catch { }
    }
}
