@page "/onboarding"
@layout TradeLedger.Components.Layout.EmptyLayout
@using Data.Models
@using TradeLedger.Services
@inject HoursTrackerService TrackerService
@inject NavigationManager Navigation

<div class="onboarding-page">

    @* ── Step 0: Welcome ── *@
    @if (step == 0)
    {
        <div class="ob-screen animate-in">
            <div class="ob-brand">
                <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" fill="currentColor" class="ob-logo-icon" viewBox="0 0 16 16">
                    <path d="M1 11a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1v-3zm5-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V7zm5-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V2z"/>
                </svg>
                <h1 class="ob-app-name">TradeLedger</h1>
            </div>
            <div class="ob-hero">
                <h2 class="ob-headline">Track your hours.<br/>Know your tax.</h2>
                <p class="ob-subline">Built for tradespeople, freelancers and the self-employed. Log shifts, see your earnings, stay on top of what you owe.</p>
            </div>
            <button class="btn-ob-primary" @onclick="() => step = 1">Get Started</button>
        </div>
    }

    @* ── Step 1: Hourly Rate ── *@
    @if (step == 1)
    {
        <div class="ob-screen animate-in">
            <div class="ob-step-indicator">
                <div class="step-dot active"></div>
                <div class="step-dot"></div>
                <div class="step-dot"></div>
            </div>
            <div class="ob-content">
                <h2 class="ob-step-title">What's your<br/>hourly rate?</h2>
                <p class="ob-step-sub">You can change this any time in Settings.</p>
                <div class="ob-input-group">
                    <span class="ob-input-prefix">£</span>
                    <input class="ob-input" type="number" min="0" step="0.50" placeholder="0.00"
                           @bind="hourlyWage" @bind:event="oninput" />
                </div>
            </div>
            <div class="ob-nav">
                <button class="btn-ob-back" @onclick="() => step = 0">Back</button>
                <button class="btn-ob-primary" @onclick="() => step = 2">Continue</button>
            </div>
        </div>
    }

    @* ── Step 2: Tax Rate ── *@
    @if (step == 2)
    {
        <div class="ob-screen animate-in">
            <div class="ob-step-indicator">
                <div class="step-dot active"></div>
                <div class="step-dot active"></div>
                <div class="step-dot"></div>
            </div>
            <div class="ob-content">
                <h2 class="ob-step-title">What's your<br/>tax rate?</h2>
                <p class="ob-step-sub">UK basic rate is 20%. Higher rate is 40%.</p>
                <div class="ob-input-group">
                    <input class="ob-input" type="number" min="0" max="100" step="1" placeholder="20"
                           @bind="taxRatePercent" @bind:event="oninput" />
                    <span class="ob-input-suffix">%</span>
                </div>
            </div>
            <div class="ob-nav">
                <button class="btn-ob-back" @onclick="() => step = 1">Back</button>
                <button class="btn-ob-primary" @onclick="() => step = 3">Continue</button>
            </div>
        </div>
    }

    @* ── Step 3: Pay Period ── *@
    @if (step == 3)
    {
        <div class="ob-screen animate-in">
            <div class="ob-step-indicator">
                <div class="step-dot active"></div>
                <div class="step-dot active"></div>
                <div class="step-dot active"></div>
            </div>
            <div class="ob-content">
                <h2 class="ob-step-title">How do you<br/>get paid?</h2>
                <p class="ob-step-sub">This sets your earnings period for tracking.</p>
                <div class="ob-period-toggle">
                    <button class="@(payPeriodType == PayPeriodType.Monthly ? "period-btn active" : "period-btn")"
                            @onclick="() => payPeriodType = PayPeriodType.Monthly">Monthly</button>
                    <button class="@(payPeriodType == PayPeriodType.Weekly ? "period-btn active" : "period-btn")"
                            @onclick="() => payPeriodType = PayPeriodType.Weekly">Weekly</button>
                </div>
                @if (payPeriodType == PayPeriodType.Monthly)
                {
                    <label class="ob-label">
                        Period starts on day
                        <input class="ob-input small" type="number" min="1" max="28" step="1"
                               @bind="payPeriodStartDay" @bind:event="oninput" />
                    </label>
                }
                else
                {
                    <label class="ob-label">
                        Week starts on
                        <select class="ob-select" @bind="payPeriodStartDay">
                            <option value="1">Monday</option>
                            <option value="2">Tuesday</option>
                            <option value="3">Wednesday</option>
                            <option value="4">Thursday</option>
                            <option value="5">Friday</option>
                            <option value="6">Saturday</option>
                            <option value="0">Sunday</option>
                        </select>
                    </label>
                }
            </div>
            <div class="ob-nav">
                <button class="btn-ob-back" @onclick="() => step = 2">Back</button>
                <button class="btn-ob-primary" @onclick="FinishSetup" disabled="@isSaving">
                    @(isSaving ? "Saving…" : "Start Tracking")
                </button>
            </div>
        </div>
    }

</div>

@code {
    private int step = 0;
    private double hourlyWage = 0;
    private double taxRatePercent = 20;
    private PayPeriodType payPeriodType = PayPeriodType.Monthly;
    private int payPeriodStartDay = 1;
    private bool isSaving;

    private async Task FinishSetup()
    {
        isSaving = true;
        var settings = await TrackerService.GetSettingsAsync();
        settings.HourlyWage = hourlyWage;
        settings.TaxRate = Math.Clamp(taxRatePercent, 0, 100) / 100.0;
        settings.PayPeriodType = payPeriodType;
        settings.PayPeriodStartDay = payPeriodType == PayPeriodType.Monthly
            ? Math.Clamp(payPeriodStartDay, 1, 28)
            : Math.Clamp(payPeriodStartDay, 0, 6);
        settings.IsOnboarded = true;
        await TrackerService.SaveSettingsAsync(settings);
        Navigation.NavigateTo("/", forceLoad: false);
    }
}
